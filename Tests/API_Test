import requests
from datetime import datetime

API_URL = "http://10.0.0.3:3000/api/sensors/data";
# Beispiel-Sensordaten
sensor_data = {
    "cluster": "weather",
    "sensor": "temperature",
    "value": 23.7,
    "unit": "°C",
    "ts": datetime.utcnow().isoformat() + "Z"  # UTC-Zeitstempel
}

try:
    response = requests.post(API_URL, json=sensor_data)
    response.raise_for_status()  # wirft Fehler bei 4xx/5xx
    print("Server Response:", response.json())
except requests.exceptions.RequestException as e:
    print("Error sending sensor data:", e)